# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Runtime logs
run_app.log
*.log

# pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# mypy / ruff caches
.mypy_cache/
.ruff_cache/

# Reproducible-build artefacts (ADR-0008)
# uv.lock IS committed (source of truth); the requirements file exported
# from it in CI is regenerated on every run and must not be committed.
requirements.locked.txt
.mutmut-cache*/
