[run]
branch = True
source = .
omit =
    tests/*
    */__pycache__/*
    build/*
    dist/*
    setup.py
    setup_env.py
    download_sbert_models.py
    # Optional heavy-stack modules that require torch + transformers
    # (and a downloaded HF checkpoint) to exercise meaningfully. Covered
    # by nightly integration runs, not unit tests.
    t5_summarizer.py
    ml_mlm_pretrain.py
    # Deprecated re-export shims (warn on import, code lives elsewhere)
    utils/__init__.py
    utils/excel_utils.py
    utils/t5_summarizer.py
    # Legacy entrypoint kept for back-compat
    bank_reason_trainer/__main__.py
    # Voilà UI panels — ipywidgets-lifecycle code; covered end-to-end
    # by tests/test_voila_smoke.py + the `web-smoke` CI job, not by
    # unit tests.  Pure-logic modules ui_widgets/theme.py and
    # ui_widgets/session.py stay IN coverage (71% / 88%).
    ui_widgets/apply_panel.py
    ui_widgets/cluster_panel.py
    ui_widgets/train_panel.py
    ui_widgets/notebook_app.py
    ui_widgets/io.py
    ui_widgets/predictions_table.py
    ui_widgets/progress.py
    ui_widgets/trust_prompt.py
    ui_widgets/dialogs/*

[report]
exclude_also =
    # Defensive import-guards are exercised only when deps missing
    except ImportError.*:
    pragma: no cover
    if TYPE_CHECKING:
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.$
fail_under = 72
precision = 2
show_missing = True
skip_covered = True
